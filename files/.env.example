# Environment Variables — Second Store Loan
# Copy file ini ke .env dan isi nilai sebenarnya

APP_NAME="Second Store Loan"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Database (MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=second_store_loan
DB_USERNAME=root
DB_PASSWORD=

# Auth
JWT_SECRET=
JWT_TTL=60

# Mail (opsional)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
